{
  "name": "tonyfettes/tree_sitter_typescript",
  "version": "0.1.25",
  "deps": {
    "tonyfettes/tree_sitter_language": "0.1.3"
  },
  "repository": "https://github.com/tree-sitter/tree-sitter-typescript",
  "license": "MIT",
  "description": "TypeScript and TSX grammars for tree-sitter",
  "keywords": [
    "tree-sitter",
    "typescript"
  ],
  "include": [
    "grammar.json",
    "node-types.json",
